{
  "name": "@openzosma/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "migrate": "tsx src/migrate.ts up",
    "migrate:down": "tsx src/migrate.ts down"
  },
  "dependencies": {
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
